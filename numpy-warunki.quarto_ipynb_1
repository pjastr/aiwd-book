      "source": [
        "#| echo: true\n",
        "import numpy as np\n",
        "\n",
        "# Tworzenie siatki indeksów 3x4\n",
        "grid = np.indices((3, 4))\n",
        "print(grid.shape)  # (2, 3, 4)\n",
