    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "import numpy as np\n",
        "\n",
        "# Siatka punktów w zakresie od -2 do 2 z krokiem 0.1\n",
        "x, y = np.ogrid[-2:2:0.1, -2:2:0.1]\n",
        "maska = x**2 + y**2 <= 1  # Okrąg o promieniu 1\n",
        "print(maska.shape)  # (40, 40)"
