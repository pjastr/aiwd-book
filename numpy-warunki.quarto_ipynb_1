    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: true\n",
        "import numpy as np\n",
        "\n",
        "arr = np.array([[10, 30, 20], [60, 40, 50]])\n",
        "indeksy_kolejnosc = np.argsort(arr, axis=1)\n",
        "wynik = np.take_along_axis(arr, indeksy_kolejnosc, axis=1)\n",
        "print(wynik)\n",
        "# [[10 20 30]\n",
        "#  [40 50 60]]"
