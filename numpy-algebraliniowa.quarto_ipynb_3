      " [ 9 12]]\n"
     ]
    }
   ],
   "source": [
    "#| echo: true\n",
    "import numpy as np\n",
    "\n",
    "# Dla 2D -- identyczne wyniki\n",
    "a = np.array([[1, 2], [3, 4]])\n",
    "b = np.array([[5, 6], [7, 8]])\n",
    "\n",
    "print(\"dot:\", np.dot(a, b)[0])\n",
    "print(\"matmul:\", np.matmul(a, b)[0])\n",
    "\n",
    "# Różnica: matmul nie akceptuje skalarów\n",
    "try:\n",
    "    np.matmul(a, 3)\n",
    "except ValueError as e:\n",
    "    print(\"matmul ze skalarem:\", e)\n",
    "\n",
    "print(\"dot ze skalarem:\", np.dot(a, 3))"
