    "# Algebra liniowa\n",
    "\n",
    "\n",
    "\n",
    "## Iloczyn skalarny (dot product)\n",
    "\n",
    "Dla dwóch wektorów, `dot` oblicza ich iloczyn skalarny."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "d0e39c7e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "32\n",
      "32\n"
     ]
    }
   ],
   "source": [
    "#| echo: true\n",
    "import numpy as np\n",
    "\n",
    "# Iloczyn skalarny dwóch wektorów\n",
    "a = np.array([1, 2, 3])\n",
    "b = np.array([4, 5, 6])\n",
    "result = np.dot(a, b)  # 1*4 + 2*5 + 3*6\n",
    "print(result)  # Wynik: 32\n",
    "\n",
    "# Alternatywny zapis za pomocą operatora @\n",
    "result = a @ b\n",
    "print(result)  # Wynik: 32"
   ]
  },
  {
